{
  "id": "import1",
  "halt-on-errors": false,
  "dataset": {
    "id": "ds1",    
    "selector": "\\root",
    
    "source": {
      "_type": "guzzle",
      "host": "http://localhost:8080/data/data-root.csv",
      "contentType": "text/csv"
    },
    
    "mapping": {
      "olaf": "{{ ds1.school_id | trim | lowercase }}"
    },
    
    "validate": [
      {
        "field": "active",
        "validations": [
          {
            "_type": "isTrue"
          }
        ]
      },
      {
        "field": "school_id",
        "validations": [
          {
            "_type": "isInteger"
          }
        ]
      }
    ],
    
    "children": [
      {
        "id": "ds2",
        "selector": "\\root\\array\\item\\id={{ ds1.school_id }}",
        "source": {
          "_type": "guzzle",
          "contentType": "application/json",
          "host": "http://localhost/import/example/data-school.json"
        }
      },
      {
        "id": "ds3",
        "selector": "\\root\\elements\\user\\id={{ ds1.school_id }}",
        "source": {
          "_type": "guzzle",
          "contentType": "application/xml",
          "host": "http://localhost/import/example/data-rest.xml"
        },
        "children": [
          {
          }
        ]
      }
    ]
  },
  "filter": {
    "rootId": [
      {
        "_type": "NotEmpty"
      }
    ]
  },
  "mapping": {
    "rootId": "{{ ds1.id }}",
    "name": "{{ ds1.name }}",
    "schoolId": "{{ ds1.scool_id }}"
  }
}
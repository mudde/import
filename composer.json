{
    "name": "mudde/import",
    "description": "import records from multiple sources",
    "type": "library",
    "require": {
        "symfony/serializer": "6.1.x-dev",
        "symfony/dom-crawler": "6.1.x-dev",
        "mustache/mustache": "dev-main",
        "symfony/validator": "6.1.x-dev",
        "guzzlehttp/guzzle": "^7.0",
        "psr/http-client": "1.0.x-dev",
        "monolog/monolog": "3.x-dev",
        "psr/log": "3.x-dev",
        "symfony/string": "6.1.x-dev"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": { "Mudde\\Import\\": "src" }
    },
    "authors": [
        {
            "name": "mudde",
